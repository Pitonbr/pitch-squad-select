---
import Base from "@/layouts/Base.astro";
import StoreBadges from "@/components/StoreBadges.astro";

const DIFFS = [
  { icon: "📱", title: "Check-in por QR code", text: "O jogador chega, escaneia e confirma. Sem discussão.", bg: "bg-ss-brand-soft", color: "text-ss-brand" },
  { icon: "⏱️", title: "Cronômetro e placar ao vivo", text: "Gols, assistências, cartões e substituições em tempo real.", bg: "bg-ss-royal-soft", color: "text-ss-royal" },
  { icon: "📋", title: "Súmula digital automática", text: "No fim da partida, súmula completa pronta pra mandar no grupo.", bg: "bg-ss-coral-soft", color: "text-ss-coral-deep" },
  { icon: "🏆", title: "Estatísticas que viram ranking", text: "Cada gol alimenta o ranking. O artilheiro sabe que é artilheiro.", bg: "bg-ss-amber-soft", color: "text-ss-amber-deep" },
];
---
<Base title="Partida ao vivo: placar, check-in QR e súmula digital | Soccer Squad" description="Registre o placar em tempo real, confirme presença por QR code e gere a súmula automática. O árbitro digital do futebol amador." path="/ao-vivo">

  <section class="bg-ss-brand-soft">
    <div class="mx-auto max-w-6xl px-4 py-16 md:py-24 grid items-center gap-12 md:grid-cols-2">
      <div>
        <span class="ss-eyebrow text-ss-brand">Funcionalidade exclusiva</span>
        <h1 class="mt-4 text-4xl md:text-5xl font-display font-black text-ss-ink">Sua pelada, transmitida <span class="text-ss-brand">ao vivo.</span></h1>
        <p class="mt-4 max-w-md text-lg text-ss-brand leading-relaxed">Check-in por QR, placar em tempo real, eventos lance a lance e súmula digital no fim.</p>
        <StoreBadges class="mt-8" />
      </div>
      <div class="mx-auto w-full max-w-sm rounded-2xl border border-black/8 bg-white p-5 shadow-[0_24px_60px_-24px_rgba(15,110,86,0.30)]">
        <div class="flex items-center justify-between">
          <p class="font-display font-extrabold text-sm">Copa do Bairro — Semi</p>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-ss-coral-soft px-2.5 py-1 text-xs font-semibold text-ss-coral-deep"><span class="ss-live-dot h-2 w-2 rounded-full bg-ss-coral"></span> AO VIVO</span>
        </div>
        <p class="mt-3 font-display text-5xl font-black tracking-tight">4 <span class="text-ss-ink/30">×</span> 3</p>
        <p class="text-xs text-ss-ink/50 mt-1">2º tempo · 22 min</p>
        <div class="mt-4 space-y-2 border-t border-black/5 pt-4 text-sm">
          <p class="flex justify-between"><span>⚽ Gol — Dudu</span><span class="text-ss-ink/40">42'</span></p>
          <p class="flex justify-between"><span>🅰️ Assist. — Marcão</span><span class="text-ss-ink/40">42'</span></p>
          <p class="flex justify-between"><span>🟨 Amarelo — Gaúcho</span><span class="text-ss-ink/40">35'</span></p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-20">
    <h2 class="ss-reveal text-3xl font-display font-black">O que nenhum outro app de pelada faz</h2>
    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      {DIFFS.map(d => (
        <article class:list={["ss-reveal rounded-2xl p-6", d.bg]}>
          <span class="text-2xl">{d.icon}</span>
          <h3 class:list={["mt-3 text-lg font-extrabold", d.color]}>{d.title}</h3>
          <p class:list={["mt-2 text-sm leading-relaxed", d.color]}>{d.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-20">
    <div class="ss-reveal rounded-3xl bg-ss-ink p-8 md:p-12 text-white">
      <p class="ss-eyebrow text-ss-lime">Por que trocar?</p>
      <h2 class="mt-3 text-3xl font-display font-black">Outros apps marcam o gol. O Soccer Squad narra a partida.</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-3 text-sm">
        <div><p class="font-extrabold text-ss-lime">Outros apps</p><p class="mt-2 text-white/60">Sorteio + lista de gols no fim. Sem cronômetro, sem check-in.</p></div>
        <div><p class="font-extrabold text-ss-lime">Soccer Squad</p><p class="mt-2 text-white/60">QR check-in, placar ao vivo, escalações visuais e súmula digital.</p></div>
        <div><p class="font-extrabold text-ss-lime">Preço</p><p class="mt-2 text-white/60">R$ 59,90/mês por time inteiro — até 40% menos que apps similares.</p></div>
      </div>
      <StoreBadges class="mt-8" />
    </div>
  </section>
</Base>
