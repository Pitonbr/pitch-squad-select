---
import "@/styles/global.css";
import { APP } from "@/lib/constants";

interface Props {
  title: string;
  description: string;
  path?: string;
  ogImage?: string;
}

const { title, description, path = "/", ogImage = "/img/og-cover.png" } = Astro.props;
const canonical = `https://${APP.domain}${path}`;
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={APP.name} />
  <meta property="og:locale" content="pt_BR" />
  <meta property="og:image" content={`https://${APP.domain}${ogImage}`} />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Smart App Banners (iOS + Android) -->
  <meta name="apple-itunes-app" content="app-id=0000000000" />
  <meta name="google-play-app" content="app-id=com.soccersquad.app" />

  <!-- Favicon (substituir por asset real) -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Schema.org MobileApplication -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MobileApplication",
    name: APP.name,
    operatingSystem: "iOS, Android",
    applicationCategory: "SportsApplication",
    description,
    url: canonical,
    offers: { "@type": "Offer", price: "59.90", priceCurrency: "BRL" },
  })} />

  <!-- GTM (substituir GTM-XXXXXX pelo ID real) -->
  <!-- <script>(function(w,d,s,l,i){...})(window,document,'script','dataLayer','GTM-XXXXXX');</script> -->

  <slot name="head" />
</head>
<body class="min-h-screen">

  <!-- ===== HEADER ===== -->
  <header class="sticky top-0 z-50 bg-ss-paper/95 backdrop-blur border-b border-black/5">
    <div class="ss-band" aria-hidden="true"><span/><span/><span/><span/><span/></div>
    <div class="mx-auto max-w-6xl px-4 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5" aria-label="Soccer Squad — início">
        <span class="flex h-9 w-9 items-center justify-center rounded-full bg-ss-brand text-white font-display font-extrabold text-sm">SS</span>
        <span class="font-display font-extrabold text-lg tracking-tight">Soccer Squad</span>
      </a>

      <nav class="hidden md:flex items-center gap-7" aria-label="Navegação principal">
        <a href="/ao-vivo" class="text-sm font-medium text-ss-ink/70 hover:text-ss-ink transition-colors">Ao vivo</a>
        <a href="/torneios" class="text-sm font-medium text-ss-ink/70 hover:text-ss-ink transition-colors">Torneios</a>
        <a href="/sorteio" class="text-sm font-medium text-ss-ink/70 hover:text-ss-ink transition-colors">Sorteio grátis</a>
        <a href="/quadras" class="text-sm font-medium text-ss-ink/70 hover:text-ss-ink transition-colors">Para quadras</a>
        <a href="/planos" class="text-sm font-medium text-ss-ink/70 hover:text-ss-ink transition-colors">Planos</a>
      </nav>

      <a href={APP.android} class="hidden md:inline-flex rounded-full bg-ss-brand px-5 py-2.5 text-sm font-semibold text-white hover:bg-ss-brand-vivid transition-colors">
        Baixar grátis
      </a>

      <!-- Mobile menu toggle -->
      <button id="menu-toggle" class="md:hidden p-2" aria-label="Abrir menu" aria-expanded="false">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>

    <nav id="mobile-menu" class="md:hidden hidden border-t border-black/5 bg-ss-paper px-4 py-4 flex flex-col gap-1" aria-label="Menu móvel">
      <a href="/ao-vivo" class="rounded-lg px-3 py-3 text-base font-medium hover:bg-ss-brand-soft">Ao vivo</a>
      <a href="/torneios" class="rounded-lg px-3 py-3 text-base font-medium hover:bg-ss-brand-soft">Torneios</a>
      <a href="/sorteio" class="rounded-lg px-3 py-3 text-base font-medium hover:bg-ss-brand-soft">Sorteio grátis</a>
      <a href="/quadras" class="rounded-lg px-3 py-3 text-base font-medium hover:bg-ss-brand-soft">Para quadras</a>
      <a href="/planos" class="rounded-lg px-3 py-3 text-base font-medium hover:bg-ss-brand-soft">Planos</a>
      <a href={APP.android} class="mt-2 rounded-full bg-ss-brand px-5 py-3 text-center text-base font-semibold text-white">Baixar grátis</a>
    </nav>
  </header>

  <!-- ===== CONTEÚDO ===== -->
  <main>
    <slot />
  </main>

  <!-- ===== FOOTER ===== -->
  <footer class="bg-ss-ink text-white/80">
    <div class="ss-band" aria-hidden="true"><span/><span/><span/><span/><span/></div>
    <div class="mx-auto max-w-6xl px-4 py-12 grid gap-10 md:grid-cols-4">
      <div>
        <p class="font-display font-extrabold text-white text-lg">Soccer Squad</p>
        <p class="mt-2 text-sm leading-relaxed">O clube digital completo do futebol amador brasileiro.</p>
        <div class="mt-4 flex gap-3">
          <a href={APP.ios} class="rounded-lg bg-white/10 px-4 py-2 text-xs font-semibold text-white hover:bg-white/20 transition-colors">App Store</a>
          <a href={APP.android} class="rounded-lg bg-white/10 px-4 py-2 text-xs font-semibold text-white hover:bg-white/20 transition-colors">Google Play</a>
        </div>
      </div>
      <nav aria-label="Produto" class="text-sm">
        <p class="ss-eyebrow text-ss-lime mb-3">Produto</p>
        <ul class="space-y-2">
          <li><a href="/ao-vivo" class="hover:text-white">Partida ao vivo</a></li>
          <li><a href="/torneios" class="hover:text-white">Torneios</a></li>
          <li><a href="/sorteio" class="hover:text-white">Sorteio de times grátis</a></li>
          <li><a href="/planos" class="hover:text-white">Planos e preços</a></li>
        </ul>
      </nav>
      <nav aria-label="Parcerias" class="text-sm">
        <p class="ss-eyebrow text-ss-amber mb-3">Parcerias</p>
        <ul class="space-y-2">
          <li><a href="/quadras" class="hover:text-white">Cadastre sua quadra</a></li>
          <li><a href={`https://wa.me/${APP.whatsapp}?text=Quero%20cadastrar%20minha%20quadra%20no%20Soccer%20Squad`} class="hover:text-white">WhatsApp comercial</a></li>
          <li><a href={`mailto:${APP.email}`} class="hover:text-white">Imprensa e mídia</a></li>
        </ul>
      </nav>
      <nav aria-label="Legal e redes" class="text-sm">
        <p class="ss-eyebrow text-ss-royal-vivid mb-3">Soccer Squad</p>
        <ul class="space-y-2">
          <li><a href="/termos" class="hover:text-white">Termos de uso</a></li>
          <li><a href="/privacidade" class="hover:text-white">Privacidade (LGPD)</a></li>
        </ul>
        <div class="mt-4 flex gap-4 text-sm">
          <a href={APP.instagram} class="hover:text-white">Instagram</a>
          <a href={APP.tiktok} class="hover:text-white">TikTok</a>
          <a href={APP.youtube} class="hover:text-white">YouTube</a>
        </div>
      </nav>
    </div>
    <div class="border-t border-white/10 py-4 text-center text-xs text-white/50">
      © 2026 Soccer Squad · soccersquad.com.br · Feito no Brasil, para quem joga de verdade.
    </div>
  </footer>

  <!-- Scripts: reveal + mobile menu (inline, sem framework) -->
  <script>
    document.getElementById("menu-toggle")?.addEventListener("click", () => {
      const menu = document.getElementById("mobile-menu");
      const btn = document.getElementById("menu-toggle");
      const open = menu?.classList.toggle("hidden") === false;
      btn?.setAttribute("aria-expanded", String(open));
    });
    const io = new IntersectionObserver(
      (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add("ss-in"); io.unobserve(e.target); } }),
      { threshold: 0.12 }
    );
    document.querySelectorAll(".ss-reveal").forEach((el) => io.observe(el));
  </script>
</body>
</html>
