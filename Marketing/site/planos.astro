---
import Base from "@/layouts/Base.astro";
import StoreBadges from "@/components/StoreBadges.astro";
import { PRICING } from "@/lib/constants";

const RECURSOS = [
  "Jogadores e times ilimitados",
  "Sorteio equilibrado e escalação visual",
  "Placar ao vivo com check-in por QR code",
  "Torneios com chaveamento automático",
  "Matchmaking e desafios entre times",
  "Estatísticas, rankings e presença",
  "Financeiro completo com lembretes",
  "Funciona offline e sincroniza sozinho",
];
---
<Base title="Planos e preços | Soccer Squad — R$ 59,90/mês por time" description="Teste grátis. Depois R$ 59,90/mês por time ou R$ 646,92/ano. Um valor único para o clube inteiro." path="/planos">

  <section class="mx-auto max-w-6xl px-4 py-16 md:py-20 text-center">
    <h1 class="text-4xl md:text-5xl font-display font-black">Um preço. O time inteiro.</h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-ss-ink/65">Sem cobrança por jogador, sem recursos escondidos. Teste grátis dentro do app.</p>

    <div class="mx-auto mt-12 grid max-w-3xl gap-5 md:grid-cols-2">
      <div class="ss-reveal rounded-3xl border border-black/10 bg-white p-8 text-left">
        <p class="ss-eyebrow text-ss-ink/50">Mensal</p>
        <p class="mt-3 font-display text-4xl font-black">R$ {PRICING.monthly}<span class="text-base font-semibold text-ss-ink/45">/mês</span></p>
        <p class="mt-1 text-sm text-ss-ink/55">por time, tudo incluído</p>
        <StoreBadges class="mt-6" />
      </div>
      <div class="ss-reveal relative rounded-3xl border-2 border-ss-brand bg-white p-8 text-left">
        <span class="absolute -top-3.5 left-8 rounded-full bg-ss-brand px-4 py-1 text-xs font-bold text-white">MAIS ESCOLHIDO · ECONOMIZE R$ {PRICING.annualSavings}</span>
        <p class="ss-eyebrow text-ss-brand">Anual</p>
        <p class="mt-3 font-display text-4xl font-black">R$ {PRICING.annualPerMonth}<span class="text-base font-semibold text-ss-ink/45">/mês</span></p>
        <p class="mt-1 text-sm text-ss-ink/55">R$ {PRICING.annual} cobrados por ano (10% off)</p>
        <StoreBadges class="mt-6" />
      </div>
    </div>

    <div class="ss-reveal mx-auto mt-12 max-w-3xl rounded-3xl bg-ss-brand-soft p-8 text-left">
      <p class="font-extrabold text-ss-brand">Tudo isso, nos dois planos:</p>
      <ul class="mt-4 grid gap-3 sm:grid-cols-2">
        {RECURSOS.map(r => (
          <li class="flex items-start gap-2.5 text-sm text-ss-brand">
            <svg class="mt-0.5 h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            {r}
          </li>
        ))}
      </ul>
    </div>

    <p class="ss-reveal mx-auto mt-8 max-w-xl text-sm text-ss-ink/55">
      Desafios contra outros times têm taxa de R$ {PRICING.challengeFee} por equipe. Cancele quando quiser.
    </p>
  </section>
</Base>
